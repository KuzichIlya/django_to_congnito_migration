# ============================================================
# Company & User Management — required environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# ------------------------------------------------------------------
# AWS credentials
#
# boto3 resolves credentials in this order:
#   1. Environment variables below          ← easiest for local / Docker
#   2. ~/.aws/credentials + ~/.aws/config
#   3. EC2/ECS instance role (no keys needed when running on AWS)
#
# Required IAM permissions for boto3 admin ops:
#   cognito-idp:AdminGetUser
#   cognito-idp:AdminDeleteUser   (if you call admin delete)
# ------------------------------------------------------------------

# Static IAM credentials (local dev / CI — do NOT commit real values)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Optional: only needed for temporary credentials (STS / SSO / assumed role)
# AWS_SESSION_TOKEN=

# ------------------------------------------------------------------
# AWS Cognito
# ------------------------------------------------------------------

# AWS region where your User Pool lives (e.g. us-east-1, eu-west-1)
COGNITO_REGION=us-east-1

# User Pool ID — found in the Cognito console under "User pools"
# Format: <region>_<AlphaNum>   e.g. us-east-1_AbCdEfGhI
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# App client ID — found under your User Pool > "App clients"
# Used to verify the `aud` claim on ID tokens.
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------
# PostgreSQL (asyncpg DSN)
# ------------------------------------------------------------------

# Full async DSN used by SQLAlchemy + asyncpg.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=xxxx

# ------------------------------------------------------------------
# Application (optional)
# ------------------------------------------------------------------

# Public base URL of the app; used for any absolute URL construction.
# Default: http://localhost:8001
APP_BASE_URL=http://localhost:8001
